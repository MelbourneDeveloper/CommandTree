# Build the project
build:
    echo "Building..."

# Run tests
test:
    echo "Testing..."

# Deploy with environment
deploy env="staging":
    echo "Deploying to {{env}}..."

# Private task (won't be shown)
_internal:
    echo "Internal task"

# Lint code with optional fix
lint fix="false":
    echo "Linting with fix={{fix}}"

# Format source code
format:
    echo "Formatting..."
